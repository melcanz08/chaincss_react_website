.navbar {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  padding: 1rem 5%;
  position: fixed;
  width: 100%;
  top: 0;
  z-index: 1000;
  box-shadow: 0 2px 20px rgba(0,0,0,0.1);
}
.nav-container {
  margin: 0 auto;
  max-width: 1200px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.logo a {
  text-decoration: none;
  font-size: 1.8rem;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea, #764ba2);
  background-clip: text;
  text-fill-color: transparent;
  letter-spacing: -0.5px;
}
.nav-links {
  gap: 2rem;
  display: flex;
  align-items: center;
}
.nav-links a {
  text-decoration: none;
  color: #1e293b;
  font-weight: 500;
  transition: color 0.3s;
}
.nav-links a:hover {
  color: #667eea;
}
.npm-badge {
  background: #1e293b;
  font-size: 0.9rem;
  color: white !important;
  padding: 0.5rem 1rem;
  border-radius: 20px;
}
.npm-badge:hover {
  background: #667eea !important;
  color: white !important;
}
.hero {
  color: white;
  text-align: center;
  padding: 120px 5% 80px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
.hero-content {
  margin: 0 auto;
  max-width: 800px;
}
.hero h1 {
  margin-bottom: 1rem;
  font-size: 3.5rem;
  animation: fadeInUp 0.8s ease;
}
.hero .tagline {
  font-size: 1.3rem;
  opacity: 0.95;
  margin-bottom: 2rem;
  animation: fadeInUp 1s ease;
}
.stats {
  justify-content: center;
  display: flex;
  gap: 3rem;
  margin: 2rem 0;
  animation: fadeInUp 1.2s ease;
}
.stat-item {
  text-align: center;
}
.stat-number {
  font-size: 2.5rem;
  font-weight: 700;
  display: block;
}
.stat-label {
  font-size: 0.9rem;
  opacity: 0.9;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.cta-buttons {
  justify-content: center;
  display: flex;
  gap: 1rem;
  animation: fadeInUp 1.4s ease;
}
.cta-primary, .cta-secondary {
  text-decoration: none;
  padding: 1rem 2rem;
  border-radius: 30px;
  font-weight: 600;
  transition: transform 0.3s, box-shadow 0.3s;
}
.cta-primary {
  background: white;
  color: #667eea;
}
.cta-secondary {
  color: white;
  background: transparent;
  border: 2px solid white;
}
.cta-primary:hover, .cta-secondary:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}
.features {
  padding: 80px 5%;
  background: #f8fafc;
}
.section-title {
  text-align: center;
  font-size: 2.5rem;
  color: #1e293b;
  margin-bottom: 3rem;
}
.features-grid {
  gap: 2rem;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  max-width: 1200px;
}
.feature-card {
  background: white;
  padding: 2rem;
  border-radius: 10px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.05);
  transition: transform 0.3s;
}
.feature-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 25px rgba(102, 126, 234, 0.2);
}
.feature-icon {
  font-size: 2.5rem;
  margin-bottom: 1rem;
}
.feature-card h3 {
  color: #1e293b;
  margin-bottom: 0.5rem;
}
.feature-card p {
  color: #64748b;
}
.code-example {
  padding: 80px 5%;
  background: white;
}
.example-container {
  gap: 2rem;
  background: #1e293b;
  border-radius: 10px;
  max-width: 1500px;
  margin: 50px auto;
  overflow: hidden;
  box-shadow: 0 20px 30px rgba(0,0,0,0.2);
}
.code-block {
  padding: 2rem;
  font-family: 'Fira Code', monospace;
  font-size: 0.9rem;
  background: #0f172a;
  color: #e2e8f0;
  line-height: 1.5;
}
.code-block pre {
  margin: 0;
  white-space: pre-wrap;
}
.output-block {
  padding: 2rem;
  background: #1e293b;
  color: white;
  white-space: wrap;
}
.output-block h3 {
  margin-bottom: 1rem;
  font-size: 0.9rem;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.css-output {
  font-family: 'Fira Code', monospace;
  background: #0f172a;
  padding: 1rem;
  border-radius: 5px;
  color: #a5f3fc;
}
.css-output pre {
  white-space: pre-wrap;
  overflow-wrap: break-word;
}
.installation {
  padding: 80px 5%;
  text-align: center;
  background: #f1f5f9;
}
.install-command {
  background: #1e293b;
  color: white;
  border-radius: 10px;
  font-family: 'Fira Code', monospace;
  padding: 1.5rem;
  font-size: 1.2rem;
  max-width: 500px;
  margin: 2rem auto;
  position: relative;
  cursor: pointer;
  transition: transform 0.3s;
}
.install-command:hover {
  transform: scale(1.02);
}
.install-command::after {
  content: '📋';
  position: absolute;
  right: 1rem;
  opacity: 0.5;
}
.install-command:hover::after {
  opacity: 1;
}
.footer {
  background: #1e293b;
  color: white;
  text-align: center;
  padding: 3rem 5%;
}
.footer-links {
  justify-content: center;
  gap: 2rem;
  display: flex;
  margin-bottom: 2rem;
}
.footer-links a {
  text-decoration: none;
  color: #94a3b8;
  transition: color 0.3s;
}
.footer-links a:hover {
  color: white;
}
.copyright {
  font-size: 0.9rem;
  color: #64748b;
}



@keyframes fadeInUp {
	from {
  opacity: 0;
  transform: translateY(20px);
}

to {
  opacity: 1;
  transform: translateY(0);
}
}

/* Responsive */
@media (max-width: 768px) {
	.hero h1 {
  font-size: 2.5rem;
}

.stats {
  flex-direction: column;
  gap: 1rem;
}

.cta-buttons {
  flex-direction: column;
  align-items: center;
}

.example-container {
  grid-template-columns: 1fr;
}

.nav-links {
  display: none;
}
}