{
  "name": "ccss_reactjs_site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx @melcanz85/chaincss ./src/main.jcss ./src/style --watch\" \"npx vite\"",
    "build": "npx chaincss ./src/main.jcss ./src/style && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "update": "git add . && git commit -m 'Update site' && git push origin main && npm run deploy"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "gh-pages": "^6.3.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@melcanz85/chaincss": "file:../chaincss",
    "autoprefixer": "^10.4.27",
    "browserslist": "^4.28.1",
    "caniuse-db": "^1.0.30001778",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
